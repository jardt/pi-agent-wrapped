#!/usr/bin/env bash
set -euo pipefail

fail() {
  printf 'run-current-pi: %s\n' "$1" >&2
  exit 1
}

launcher=${PI_LAUNCHER_BIN-}
[[ -n "$launcher" ]] || fail "PI_LAUNCHER_BIN is required; spawned Pi processes must reuse the active wrapper"
[[ "$launcher" == /* ]] || fail "PI_LAUNCHER_BIN must be an absolute path: $launcher"
[[ -f "$launcher" ]] || fail "PI_LAUNCHER_BIN is not a regular file: $launcher"
[[ -x "$launcher" ]] || fail "PI_LAUNCHER_BIN is not executable: $launcher"

canonical_launcher="$("@readlink@" -f -- "$launcher")" \
  || fail "unable to canonicalize PI_LAUNCHER_BIN: $launcher"
[[ "$launcher" == "$canonical_launcher" ]] \
  || fail "PI_LAUNCHER_BIN must be canonical: $launcher (resolved: $canonical_launcher)"

exec "$launcher" "$@"
